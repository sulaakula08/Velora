# === Обязательные ===

# Токен Telegram-бота от @BotFather (см. README)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_telegram_bot_token_here

# Ключ Google Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# === Необязательные (есть значения по умолчанию) ===

# Модель Gemini для диалога (gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash, ...)
GEMINI_MODEL=gemini-2.5-flash

# Сколько последних сообщений диалога хранить и передавать в контекст
HISTORY_LIMIT=20

# Часовой пояс по умолчанию для напоминаний
TIMEZONE=Asia/Almaty

# Путь к файлу базы данных SQLite
DB_PATH=./velora.db

# Уровень логирования: debug | info | warn | error
LOG_LEVEL=info

# Обход ошибки "unable to verify the first certificate" при перехвате трафика
# антивирусом или VPN. Отключает проверку TLS-сертификата ТОЛЬКО для Telegram.
# Небезопасно — включай только для локальной отладки (true).
TELEGRAM_ALLOW_INSECURE_TLS=false

# Показывать реальный текст ошибки в ответе бота (для отладки). В проде — false.
DEBUG_ERRORS=false

# === Google (Calendar + Gmail) — опционально ===
# Создай OAuth Client (тип Web) в Google Cloud Console, включи Calendar API и Gmail API.
# Redirect URI должен совпадать: http://localhost:3000/oauth/callback
# Если оставить пустыми — интеграция просто выключена.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback
OAUTH_PORT=3000

# === Composio — универсальные интеграции (Gmail, Календарь, Slack, Notion...) ===
# Ключ из дашборда Composio (dashboard.composio.dev). Пусто — интеграция выключена.
# Для каждого приложения создай Auth Config в дашборде и впиши его id в COMPOSIO_AUTH_CONFIGS.
COMPOSIO_API_KEY=
COMPOSIO_CALLBACK_BASE_URL=http://localhost:3000
# JSON: slug тулкита → id auth-конфига. Поддерживаются gmail, googlecalendar,
# googlemeet, googledocs, slack, notion, github, linear. Напр.:
# {"gmail":"ac_xxx","googlecalendar":"ac_yyy","googlemeet":"ac_zzz","googledocs":"ac_www"}
COMPOSIO_AUTH_CONFIGS=

# === Биллинг (подписка Pro) через LemonSqueezy ===
# Пусто — гейтинг ВЫКЛЮЧЕН: все функции без ограничений (режим до монетизации).
# Заданы оба значения — включаются тарифы Free/Pro и webhook активации.
# Webhook в дашборде LemonSqueezy: <публичный URL>/billing/lemonsqueezy/webhook
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_CHECKOUT_URL=
# Лимиты бесплатного тарифа (можно не задавать — значения по умолчанию).
FREE_DAILY_MESSAGES=20
FREE_MAX_INTEGRATIONS=1

# === Оплата Telegram Stars (Pro прямо в боте) ===
# По умолчанию включено. Чтобы выключить — PRO_STARS_ENABLED=false.
PRO_STARS_ENABLED=true
PRO_STARS_PRICE=250        # обычная цена Pro в звёздах (~$5)
PRO_STARS_PROMO=30         # промо-цена на запуске (0 или >=обычной — акции нет)
PRO_DURATION_DAYS=30       # длительность месячного Pro
PRO_STARS_PRICE_YEAR=2000  # цена годового Pro в звёздах
PRO_DURATION_DAYS_YEAR=365
# Реферальная программа (дни Pro): бонус пригласившему и триал новому.
REFERRAL_BONUS_DAYS=7
REFERRAL_TRIAL_DAYS=7
# Пароль для бесплатной активации Pro админами: /admin <пароль>
ADMIN_PASSWORD=velora_admin
# Голос TTS (необязательно): переопределить модель/голос Gemini.
GEMINI_TTS_MODEL=
GEMINI_TTS_VOICE=
